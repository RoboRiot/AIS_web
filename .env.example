NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5

# The production URL is fixed in site.config.mjs so SEO output cannot point
# at a preview hostname or IP because of an environment-file mistake.

# Direct-IP and private preview hosts require Basic authentication and emit
# noindex headers. Never add the production domain to this list.
STAGING_HOSTS=164.92.111.36
STAGING_BASIC_AUTH_USER=
STAGING_BASIC_AUTH_PASSWORD=

# Legacy public hosts permanently redirect path-for-path to the production URL.
DEPRECATED_HOSTS=advancedimaging.duckdns.org

EMAIL_RECIPIENTS=isavchenko@advancedimagingparts.com,swang@advancedimagingparts.com,sredd@advancedimagingparts.com

# Option A: paste the full Firebase service account JSON as one env var.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Option B: use individual service account fields instead of FIREBASE_SERVICE_ACCOUNT_JSON.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
